# ─────────────────────────────────────────────────────────────────────
#  Picsi Drop – Backend Environment Variables  (.env.example)
#  Copy this to .env and fill in your values before running locally.
# ─────────────────────────────────────────────────────────────────────

# Server port
PORT=5000

# ─── LOCAL DEVELOPMENT (SQLite) ─────────────────────────────────────
# Creates a local file at backend/prisma/dev.db
DATABASE_URL="file:./prisma/dev.db"

# ─── PRODUCTION (Turso / libSQL) ────────────────────────────────────
# Get these from: https://turso.tech → your database → Connect
# DATABASE_URL="libsql://picsidrop-db-<your-org>.turso.io"
# TURSO_AUTH_TOKEN="your-turso-token-here"

# ─── PRODUCTION (PostgreSQL on Render/Supabase) ──────────────────────
# Only if you switch Prisma provider from sqlite to postgresql in schema.prisma
# DATABASE_URL="postgresql://USER:PASSWORD@HOST:PORT/DATABASE?schema=public"
