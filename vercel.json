{
  "version": 2,
  "buildCommand": "npm run build",
  "framework": null,
  "outputDirectory": ".",
  "routes": [
    { "src": "/api/(.*)", "dest": "https://picsidrop-api.onrender.com/api/$1" },
    { "src": "/index\\.html",        "dest": "/index.html" },
    { "src": "/about\\.html",        "dest": "/about.html" },
    { "src": "/features\\.html",     "dest": "/features.html" },
    { "src": "/partnerships\\.html", "dest": "/partnerships.html" },
    { "src": "/sender\\.html",       "dest": "/sender.html" },
    { "src": "/traveler\\.html",     "dest": "/traveler.html" },
    { "src": "/privacy\\.html",      "dest": "/privacy.html" },
    { "src": "/refund\\.html",       "dest": "/refund.html" },
    { "src": "/terms\\.html",        "dest": "/terms.html" },
    { "src": "/(.*)\\.html",         "dest": "/$1.html" },
    { "src": "/(.*)",                "dest": "/index.html" }
  ]
}
